# Copy this file to `.env` and fill the values you need.
# `docker compose` reads `.env` automatically (do not commit it!).

# ── Required for the chat agent ──
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Optional ──
# Override the default Claude model (must be an Anthropic ID).
# CLAUDE_MODEL=claude-sonnet-4-5

# Email used for the OpenAlex polite pool (improves rate limits).
# OPENALEX_EMAIL=you@example.org

# Comma-separated origins allowed by FastAPI's CORS middleware.
# Defaults cover the dev server (5173), Vite preview (4173), and the
# nginx-served frontend (8080) when running via docker compose.
# CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:4173
