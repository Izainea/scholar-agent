# Public DNS resolver for runtime upstream resolution. Required so that
# `proxy_pass` to an external Railway URL re-resolves the host on every
# request (otherwise nginx caches the IP at startup and 502s when it
# rotates behind Railway's edge).
resolver 1.1.1.1 8.8.8.8 ipv6=off valid=30s;
resolver_timeout 5s;

server {
    listen ${NGINX_PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Gzip text assets
    gzip on;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # Static assets — long-lived cache (Vite emits hashed filenames)
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # API proxy → FastAPI backend.
    # BACKEND_URL is baked in at build time (see frontend/Dockerfile),
    # eg. "https://backend-production-15b0.up.railway.app".
    #
    # Note: with `proxy_pass $variable`, nginx does NOT automatically
    # append the matched URI. We have to construct the upstream URL
    # ourselves, stripping the /api/ prefix in the process.
    location /api/ {
        # Capture the path after /api/ into $1 (everything that follows
        # /api/) and stash it; nginx uses this when building the URL.
        set $upstream "${BACKEND_URL}";

        # `proxy_pass $upstream$path_no_api` (where $path_no_api comes
        # from a regex on $uri) gives full control over the final URL
        # and re-resolves DNS per request (using the `resolver` above).
        set $path_no_api "";
        if ($uri ~ ^/api/(.*)$) {
            set $path_no_api "/$1";
        }
        proxy_pass $upstream$path_no_api$is_args$args;

        # External Railway upstream: edge needs SNI + matching Host
        # header so it can route to the right service.
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE / streaming friendly settings — disable buffering and
        # extend timeouts so the agent's chat stream stays alive.
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
        proxy_send_timeout 1h;
        chunked_transfer_encoding on;
    }

    # SPA routing: any unknown path serves index.html so React Router takes over.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
