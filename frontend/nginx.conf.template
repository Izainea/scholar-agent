server {
    listen ${NGINX_PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Gzip text assets
    gzip on;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # Static assets — long-lived cache (Vite emits hashed filenames)
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # SPA routing: any unknown path serves index.html so React Router takes over.
    # The frontend talks to the backend DIRECTLY via its public Railway URL
    # (baked into the bundle as VITE_API_BASE). CORS is configured on the
    # backend, so no nginx proxy is needed.
    location / {
        try_files $uri $uri/ /index.html;
    }
}
